pipeline {
    agent any
    stages {
        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/2025jaspreetchalotra-creator/college-devops.git'
            }
        }
        stage('Install Dependencies') {
            steps {
                bat 'npm install' 
            }
        }
        stage('Run Tests') {
            steps {
                bat 'npm test' 
            }
        }
    }
}